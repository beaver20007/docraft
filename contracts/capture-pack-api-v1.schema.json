{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docraft.pro/schemas/capture-pack-api-v1.schema.json",
  "title": "CapturePackApiManifest",
  "description": "Multipart manifest for Docraft POST /generate/with-captures (version 1.0)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "steps"],
  "properties": {
    "version": { "const": "1.0" },
    "source": {
      "enum": ["desktop-instructor", "web-upload", "api"]
    },
    "title": { "type": "string", "maxLength": 300 },
    "locale": { "enum": ["ru", "en"] },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/apiStep" }
    }
  },
  "$defs": {
    "apiStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "order", "image_ref"],
      "properties": {
        "step_id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "order": { "type": "integer", "minimum": 1, "maximum": 20 },
        "title": { "type": "string", "maxLength": 200 },
        "caption": { "type": "string", "maxLength": 500 },
        "image_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[^/\\\\]+$"
        },
        "section_hint": { "type": "string", "maxLength": 64 },
        "window_title": { "type": "string", "maxLength": 300 },
        "captured_at": { "type": "string", "maxLength": 40 }
      }
    }
  }
}
